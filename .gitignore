# Build and binary artifacts
/bin/
/build/

# Flutter build/metadata
flutter_ui/build/
flutter_ui/.dart_tool/

# Editor and OS files
.vscode/
.idea/
*.swp
*.log
# ── C++ build artifacts ────────────────────────────
build/
cmake-build-*/
*.o
*.a
*.so
*.dylib
CMakeCache.txt
CMakeFiles/
Makefile
*.cmake

# ── Generated gRPC C++ sources ────────────────────
src/generated/

# ── Flutter (handled by flutter_ui/.gitignore too) ─
flutter_ui/build/
flutter_ui/.dart_tool/
flutter_ui/.flutter-plugins-dependencies
flutter_ui/.packages
flutter_ui/.pub-cache/
flutter_ui/.pub/
flutter_ui/.idea/
flutter_ui/.metadata
flutter_ui/*.iml
flutter_ui/linux/flutter/ephemeral/

# Ignore ephemeral protoc output (Dart generation)
flutter_ui/lib/generated/proto/

# Ignore any nested build directories and common intermediate files
**/build/
**/out/
**/intermediates/
**/cmake_install.cmake
**/CMakeFiles/

# ── IDE / Editor ──────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Runtime ───────────────────────────────────────
*.sock
*.log
